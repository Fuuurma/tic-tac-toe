{
  "name": "tic-tac-toe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3110 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4110 --strictPort",
    "lint": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "check": "pnpm lint && pnpm test && pnpm test:e2e",
    "deploy:check": "pnpm build && node -e \"const fs=require('fs');const p='dist/index.html';if(!fs.existsSync(p)){console.error('Missing '+p);process.exit(1)}console.log('dist/ looks ready')\"",
    "deploy": "pnpm build && wrangler pages deploy dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "wrangler": "^4.112.0"
  }
}
