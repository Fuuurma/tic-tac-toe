{
  "name": "tic-tac-toe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "check": "pnpm lint && pnpm test && pnpm test:e2e",
    "deploy:check": "pnpm build && node -e \"const fs=require('fs');const p='dist/index.html';if(!fs.existsSync(p)){console.error('Missing '+p);process.exit(1)}console.log('dist/ looks ready')\"",
    "deploy": "pnpm build && wrangler pages deploy dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.110.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^5.4.0"
    }
  }
}
